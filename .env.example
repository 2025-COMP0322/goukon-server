# ===================================
# Goukon Server - Environment Variables
# ===================================
# Copy this file to .env and modify values as needed

# Database (Oracle XE)
DB_USERNAME=system
DB_PASSWORD=goukon123

# Valkey (Redis) - Default ports, no auth
VALKEY_HOST=localhost
VALKEY_PORT=6379

# RabbitMQ
RABBITMQ_USER=goukon
RABBITMQ_PASS=goukon123
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# JWT - Change these in production!
JWT_ACCESS_SECRET=your-secret-key-at-least-32-characters-long
JWT_ACCESS_EXPIRED=18000000
JWT_REFRESH_SECRET=your-refresh-secret-key-32-chars-long
JWT_REFRESH_EXPIRED=180000000

# Invite Code TTL (seconds) - Default 1 hour
INVITE_CODE_TTL=3600

# Server
SERVER_PORT=8080

# Logging
LOG_LEVEL=DEBUG
